# Get these from your Paystack Dashboard -> Settings -> API Keys & Webhooks
# https://dashboard.paystack.com/#/settings/developer

# Secret key (NEVER expose this in client-side code)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Currency for transactions. Common options: KES, NGN, GHS, ZAR, USD
# Make sure your Paystack account/business is enabled for this currency.
PAYSTACK_CURRENCY=KES
